# ══════════════════════════════════════════════════════════════════
#  RAG Decision Support System — Environment Configuration
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ══════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
DEBUG=false
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# ── Security ─────────────────────────────────────────────────────
REQUIRE_API_KEY=false            # set true in production
API_KEY=change-me-in-production
SECRET_KEY=replace-with-a-long-random-string

# ── Rate Limiting ─────────────────────────────────────────────────
ENABLE_RATE_LIMIT=true
RATE_LIMIT_RPM=60

# ── CORS (comma-separated origins) ───────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── LLM Provider ─────────────────────────────────────────────────
# Choose one: openai | anthropic | local
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Local (Ollama)
LOCAL_LLM_URL=http://localhost:11434/api/generate
LOCAL_LLM_MODEL=mistral

LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024

# ── Embeddings ────────────────────────────────────────────────────
# sentence-transformers model (downloaded automatically on first run)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=64

# ── ChromaDB ─────────────────────────────────────────────────────
USE_CHROMA_SERVER=false          # false = embedded (default), true = server
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=rag_knowledge_base
CHROMA_PERSIST_DIR=./chroma_data

# ── Retrieval ─────────────────────────────────────────────────────
RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.35
HYBRID_SEARCH_ENABLED=true
HYBRID_ALPHA=0.7                 # 1.0 = pure dense, 0.0 = pure sparse

# ── Chunking ──────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
MAX_DOCUMENT_SIZE_MB=20

# ── Sessions ──────────────────────────────────────────────────────
SESSION_TTL_MINUTES=60
MAX_HISTORY_TURNS=10
